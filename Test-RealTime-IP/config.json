            "snap7": "byte = startByte + ((index + indexShift - 1) * bytesPerDevice) + byteOffset",
            "modbus": "slaveId = index + slaveIdShift | register = registerStart",
            "iec104": "ASDU = baseAsdu + (index-1)*asduStep | IOA = baseIOA + (index-1)*ioaPerDevice + fieldOffset"
